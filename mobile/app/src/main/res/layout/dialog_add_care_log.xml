<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:id="@+id/vHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="#E5E7EB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Add Care Log"
        android:textColor="@color/gray_dark"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/vHandle" />

    <TextView
        android:id="@+id/tvTaskTypeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:letterSpacing="0.1"
        android:text="TASK TYPE"
        android:textColor="@color/gray_light"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

    <LinearLayout
        android:id="@+id/llTaskTypes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvTaskTypeLabel">

        <LinearLayout
            android:id="@+id/llWatering"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@drawable/bg_task_type_selected"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivWatering"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_water_drop"
                app:tint="@color/halaman_green" />

            <TextView
                android:id="@+id/tvWatering"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="WATERING"
                android:textColor="@color/halaman_green"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llFertilize"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_task_type_unselected"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivFertilize"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_fertilize"
                app:tint="@color/gray_light" />

            <TextView
                android:id="@+id/tvFertilize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="FERTILIZE"
                android:textColor="@color/gray_light"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llMist"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_task_type_unselected"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivMist"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_mist"
                app:tint="@color/gray_light" />

            <TextView
                android:id="@+id/tvMist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="MIST"
                android:textColor="@color/gray_light"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llPruning"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_task_type_unselected"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivPruning"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_leaf"
                app:tint="@color/gray_light" />

            <TextView
                android:id="@+id/tvPruning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="PRUNING"
                android:textColor="@color/gray_light"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:letterSpacing="0.1"
        android:text="DATE COMPLETED"
        android:textColor="@color/gray_light"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"
        app:layout_constraintTop_toBottomOf="@+id/llTaskTypes" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clDate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tvDateLabel">

        <TextView
            android:id="@+id/tvCurrentDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="March 1, 2026" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_success_banner"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="TODAY"
            android:textColor="@color/success"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvNotesLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:letterSpacing="0.1"
        android:text="NOTES (OPTIONAL)"
        android:textColor="@color/gray_light"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"
        app:layout_constraintTop_toBottomOf="@+id/clDate" />

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_field"
        android:gravity="top"
        android:hint="How is your plant doing?"
        android:padding="20dp"
        android:textColor="@color/gray_dark"
        android:textColorHint="@color/gray_light"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@+id/tvNotesLabel" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSaveLog"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_button_green"
        android:text="SAVE LOG"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/etNotes" />

    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/white"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/btnSaveLog"
        app:layout_constraintEnd_toEndOf="@+id/btnSaveLog"
        app:layout_constraintStart_toStartOf="@+id/btnSaveLog"
        app:layout_constraintTop_toTopOf="@+id/btnSaveLog" />

</androidx.constraintlayout.widget.ConstraintLayout>
