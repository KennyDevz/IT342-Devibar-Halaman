<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="24dp">

    <!-- The Track (Left Column) -->
    <View
        android:id="@+id/vLineTop"
        android:layout_width="2dp"
        android:layout_height="24dp"
        android:background="#E5E7EB"
        app:layout_constraintEnd_toEndOf="@+id/vDot"
        app:layout_constraintStart_toStartOf="@+id/vDot"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/vDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_timeline_dot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/vLineTop" />

    <View
        android:id="@+id/vLineBottom"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E5E7EB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/vDot"
        app:layout_constraintStart_toStartOf="@+id/vDot"
        app:layout_constraintTop_toBottomOf="@+id/vDot" />

    <!-- The Content Card (Right Column) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTimeline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/vDot"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivSnapshot"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/backgrounds/scenic" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gray_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="May 18, 2026" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/gray_light"
                    android:textSize="12sp"
                    tools:text="First new leaf!" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:letterSpacing="0.1"
                    android:text="GROWTH SNAPSHOT"
                    android:textColor="@color/halaman_green"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
