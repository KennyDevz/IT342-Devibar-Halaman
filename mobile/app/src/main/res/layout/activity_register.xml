<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F6F2">

    <!-- Background image — sits behind everything -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/auth_bg"
        android:scaleType="centerCrop"
        android:alpha="0.10"/>

    <!-- Scrollable content on top of background -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Top Row: Back button + Logo -->
            <LinearLayout
                android:id="@+id/topRow"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- Back Button -->
                <LinearLayout
                    android:id="@+id/btnBack"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_input_glass"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        />

                </LinearLayout>

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <!-- Small Logo -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_logo_icon"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_leaf"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halaman"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold|italic"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:layout_marginStart="8dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Title Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join Halaman"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:fontFamily="sans-serif-black"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="START YOUR GROWTH JOURNEY."
                android:textColor="#B32E7D32"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp"/>

            <!-- First Name + Last Name Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- First Name -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FIRST NAME"
                        android:textColor="@color/halaman_green"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFirstName"
                        style="@style/HalamanTextInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFirstName"
                            android:layout_width="match_parent"
                            android:layout_height="58dp"
                            android:hint="Leafy"
                            android:inputType="textPersonName"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="#FFD1D5DC"
                            android:fontFamily="sans-serif-medium"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Last Name -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAST NAME"
                        android:textColor="@color/halaman_green"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLastName"
                        style="@style/HalamanTextInputStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLastName"
                            android:layout_width="match_parent"
                            android:layout_height="58dp"
                            android:hint="Green"
                            android:inputType="textPersonName"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:textColorHint="#FFD1D5DC"
                            android:fontFamily="sans-serif-medium"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Email Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textColor="@color/halaman_green"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"/>

            <!-- Email Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/HalamanTextInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:hint="example@halaman.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#FFD1D5DC"
                    android:fontFamily="sans-serif-medium"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="@color/halaman_green"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"/>

            <!-- Password Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/HalamanTextInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/halaman_green"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#FFD1D5DC"
                    android:fontFamily="sans-serif-medium"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Confirm Password Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD"
                android:textColor="@color/halaman_green"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="6dp"/>

            <!-- Confirm Password Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/HalamanTextInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/halaman_green"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#FFD1D5DC"
                    android:fontFamily="sans-serif-medium"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Terms of Service -->
            <TextView
                android:id="@+id/tvTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <!-- Create Account Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_button_green"
                android:stateListAnimator="@null"
                android:text="CREATE ACCOUNT"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:letterSpacing="0.1"/>

            <!-- Already have account -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already a gardener? "
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvSignIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign in"
                    android:textColor="@color/halaman_green"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>